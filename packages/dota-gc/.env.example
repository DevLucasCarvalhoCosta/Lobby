# Steam Bot Credentials
# IMPORTANT: Use a separate Steam account for the bot, NOT your personal account!
# Valve can detect automated clients and may ban the account.
STEAM_BOT_USERNAME=your_bot_username
STEAM_BOT_PASSWORD=your_bot_password
STEAM_BOT_GUARD_CODE=  # Steam Guard code (if 2FA is required)

# Server Ports
GRPC_PORT=50051
HTTP_PORT=8080

# Lobby Defaults
DEFAULT_SERVER_REGION=10  # 10 = Brazil (see config.go for all regions)
DEFAULT_GAME_MODE=1       # 1 = All Pick (see config.go for all modes)

# NestJS Integration
NESTJS_WEBHOOK_URL=http://localhost:3001/api/lobby/webhook

# Debug Mode
DEBUG=false
